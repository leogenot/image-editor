---
---
<div
  id="edit-panel"
  class="
    fixed bottom-0 left-0 right-0 z-20
    md:absolute md:right-0 md:top-0 md:bottom-0 md:w-72 md:left-auto
    flex flex-col
    border-t border-white/[0.06]
    md:border-t-0 md:border-l md:border-white/[0.06]
    bg-black/85 backdrop-blur-xl
  "
  x-data="panelData()"
  x-show="$store.editor.hasImage && !$store.editor.libraryOpen"
  x-cloak
>
  <!-- Drag handle (mobile only) with collapse toggle -->
  <div class="flex justify-center items-center py-3 md:hidden relative cursor-grab active:cursor-grabbing" data-handle>
    <div class="w-8 h-[3px] bg-white/20 rounded-full"></div>
    <button
      class="absolute right-4 w-7 h-7 flex items-center justify-center text-white/30 hover:text-white/60 transition-colors"
      @click.stop="collapsed = !collapsed"
      :aria-label="collapsed ? 'Expand panel' : 'Collapse panel'"
    >
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <polyline
          :points="collapsed ? '2,4 6,8 10,4' : '2,8 6,4 10,8'"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>
  </div>

  <!-- Tab bar -->
  <div class="flex overflow-x-auto scrollbar-none flex-shrink-0 border-b border-white/[0.04] px-2">
    <template x-for="tab in tabs" :key="tab.id">
      <button
        class="flex-shrink-0 relative px-3 py-3 transition-all"
        :class="$store.editor.activePanel === tab.id
          ? 'text-white'
          : 'text-white/25 hover:text-white/50'"
        @click="$store.editor.activePanel = tab.id"
      >
        <span class="font-mono text-[9px] uppercase tracking-[0.15em]" x-text="tab.label"></span>
        <!-- Active underline -->
        <div
          class="absolute bottom-0 left-1/2 -translate-x-1/2 h-px bg-white transition-all duration-200"
          :class="$store.editor.activePanel === tab.id ? 'w-full' : 'w-0'"
        ></div>
      </button>
    </template>
  </div>

  <!-- Scrollable panel content -->
  <div class="flex-1 overflow-y-auto overscroll-contain px-4 py-1" x-show="!collapsed" x-collapse>

    <div x-show="$store.editor.activePanel === 'light'">
      <slot name="light" />
    </div>

    <div x-show="$store.editor.activePanel === 'color'">
      <slot name="color" />
    </div>

    <div x-show="$store.editor.activePanel === 'curve'">
      <slot name="curve" />
    </div>

    <div x-show="$store.editor.activePanel === 'detail'">
      <slot name="detail" />
    </div>

    <div x-show="$store.editor.activePanel === 'crop'">
      <slot name="crop" />
    </div>

    <div x-show="$store.editor.activePanel === 'frame'">
      <slot name="frame" />
    </div>

    <div x-show="$store.editor.activePanel === 'lens'">
      <slot name="lens" />
    </div>

    <div x-show="$store.editor.activePanel === 'presets'">
      <slot name="presets" />
    </div>

  </div>
</div>

<script>
import Alpine from 'alpinejs'
import { setupBottomSheet } from '../lib/bottomSheet.js'

Alpine.data('panelData', () => ({
  collapsed: false,
  tabs: [
    { id: 'light',   label: 'LIGHT'   },
    { id: 'color',   label: 'COLOR'   },
    { id: 'curve',   label: 'CURVE'   },
    { id: 'detail',  label: 'DETAIL'  },
    { id: 'crop',    label: 'CROP'    },
    { id: 'frame',   label: 'FRAME'   },
    { id: 'lens',    label: 'LENS'    },
    { id: 'presets', label: 'PRESETS' },
  ],

  init() {
    // Only set up bottom sheet on mobile
    if (window.innerWidth < 768) {
      setupBottomSheet(this.$el)
    }
  },
}))
</script>

---

---

<div
  id="canvas-container"
  class="absolute inset-0 overflow-hidden"
  :style="`background-color: ${canvasBgColor}`"
  x-data="canvasView()"
  x-show="$store.editor.hasImage && !$store.editor.libraryOpen"
  x-cloak
>
  <canvas
    id="gl-canvas"
    x-ref="canvas"
    class="absolute origin-top-left will-change-transform"
    :style="`
      width: ${naturalW}px;
      height: ${naturalH}px;
      transform: translate(${panX}px, ${panY}px) scale(${zoom});
      cursor: ${panning ? 'grabbing' : 'grab'};
      clip-path: ${$store.editor.activePanel !== 'crop' ? cropClipPath() : 'none'};
    `"
    @mousedown="startPan($event)"
    @touchstart.passive="touchStart($event)"></canvas>

  <!-- Minimap (desktop only, conditional) -->
  <div
    class="absolute top-4 left-4 pointer-events-none hidden md:block"
    x-show="showMinimap && $store.editor.activePanel !== 'crop'"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 scale-100"
    x-transition:leave-end="opacity-0 scale-95"
    style="transform-origin: top left;"
  >
    <canvas
      x-ref="minimap"
      class="block"
      style="border: 1px solid rgba(255,255,255,0.18); background: #111; box-shadow: 0 2px 12px rgba(0,0,0,0.6);"
      :width="minimapSize.w"
      :height="minimapSize.h"></canvas>
  </div>

  <!-- Background colour picker (always visible) -->
  <div
    class="absolute top-[72px] md:top-4 flex flex-col gap-1.5"
    x-show="$store.editor.activePanel !== 'crop'"
    :style="`left: ${showMinimap && $el.clientWidth >= 768 ? minimapSize.w + 24 : 16}px`"
  >
    <template x-for="bg in [{key:'black',color:'#000',border:'rgba(255,255,255,0.25)'},{key:'grey',color:'#777',border:'rgba(255,255,255,0.25)'},{key:'white',color:'#fff',border:'rgba(0,0,0,0.25)'}]" :key="bg.key">
      <button
        @click="canvasBg = bg.key"
        :title="`${bg.key} background`"
        :style="`
          width:14px;height:14px;border-radius:50%;
          background:${bg.color};
          border: ${canvasBg === bg.key ? '2px solid rgba(255,255,255,0.9)' : '1.5px solid ' + bg.border};
          box-shadow: 0 1px 4px rgba(0,0,0,0.5);
          outline: none; cursor: pointer; padding: 0;
          box-sizing: border-box;
        `"
      ></button>
    </template>
  </div>

  <!-- iOS-style crop overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    x-show="$store.editor.activePanel === 'crop'"
    style="overflow: visible;"
  >
    <!-- Crop box: box-shadow punches a hole in the dim layer -->
    <div
      class="absolute pointer-events-auto cursor-move"
      :style="cropBoxStyle()"
      @mousedown.prevent="startCropDrag($event)"
      @touchstart.prevent="startCropDragTouch($event)"
    >
      <!-- Rule of thirds grid (always visible in crop mode) -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="overflow:hidden;"
      >
        <div
          class="absolute inset-y-0"
          style="left:33.333%;width:1px;background:rgba(255,255,255,0.25)"
        >
        </div>
        <div
          class="absolute inset-y-0"
          style="left:66.666%;width:1px;background:rgba(255,255,255,0.25)"
        >
        </div>
        <div
          class="absolute inset-x-0"
          style="top:33.333%;height:1px;background:rgba(255,255,255,0.25)"
        >
        </div>
        <div
          class="absolute inset-x-0"
          style="top:66.666%;height:1px;background:rgba(255,255,255,0.25)"
        >
        </div>

        <!-- Fine grid (3×3 subdivided = 9×9) shown while straightening -->
        <template x-if="$store.editor.straightening">
          <div class="absolute inset-0">
            <template x-for="i in [1,2,3,4,5,6,7,8]" :key="'fv'+i">
              <div
                class="absolute inset-y-0"
                :style="`left:${i*11.111}%;width:1px;background:rgba(255,255,255,0.12)`"
              >
              </div>
            </template>
            <template x-for="i in [1,2,3,4,5,6,7,8]" :key="'fh'+i">
              <div
                class="absolute inset-x-0"
                :style="`top:${i*11.111}%;height:1px;background:rgba(255,255,255,0.12)`"
              >
              </div>
            </template>
          </div>
        </template>
      </div>

      <!-- White border -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="border:1px solid rgba(255,255,255,0.9)"
      >
      </div>

      <!-- Corner handles (L-shaped, thick) -->
      <!-- NW -->
      <div
        class="absolute pointer-events-auto"
        style="top:-1px;left:-1px;width:22px;height:22px;cursor:nw-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'nw')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'nw')"
      >
        <div
          style="position:absolute;top:0;left:0;width:100%;height:3px;background:white;border-radius:2px 0 0 0"
        >
        </div>
        <div
          style="position:absolute;top:0;left:0;width:3px;height:100%;background:white;border-radius:2px 0 0 0"
        >
        </div>
      </div>
      <!-- NE -->
      <div
        class="absolute pointer-events-auto"
        style="top:-1px;right:-1px;width:22px;height:22px;cursor:ne-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'ne')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'ne')"
      >
        <div
          style="position:absolute;top:0;right:0;width:100%;height:3px;background:white;border-radius:0 2px 0 0"
        >
        </div>
        <div
          style="position:absolute;top:0;right:0;width:3px;height:100%;background:white;border-radius:0 2px 0 0"
        >
        </div>
      </div>
      <!-- SW -->
      <div
        class="absolute pointer-events-auto"
        style="bottom:-1px;left:-1px;width:22px;height:22px;cursor:sw-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'sw')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'sw')"
      >
        <div
          style="position:absolute;bottom:0;left:0;width:100%;height:3px;background:white;border-radius:0 0 0 2px"
        >
        </div>
        <div
          style="position:absolute;bottom:0;left:0;width:3px;height:100%;background:white;border-radius:0 0 0 2px"
        >
        </div>
      </div>
      <!-- SE -->
      <div
        class="absolute pointer-events-auto"
        style="bottom:-1px;right:-1px;width:22px;height:22px;cursor:se-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'se')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'se')"
      >
        <div
          style="position:absolute;bottom:0;right:0;width:100%;height:3px;background:white;border-radius:0 0 2px 0"
        >
        </div>
        <div
          style="position:absolute;bottom:0;right:0;width:3px;height:100%;background:white;border-radius:0 0 2px 0"
        >
        </div>
      </div>

      <!-- Edge handles (mid-edge, small bars) -->
      <!-- N -->
      <div
        class="absolute pointer-events-auto"
        style="top:-4px;left:50%;transform:translateX(-50%);width:32px;height:8px;cursor:n-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'n')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'n')"
      >
        <div
          style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:28px;height:3px;background:white;border-radius:2px"
        >
        </div>
      </div>
      <!-- S -->
      <div
        class="absolute pointer-events-auto"
        style="bottom:-4px;left:50%;transform:translateX(-50%);width:32px;height:8px;cursor:s-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'s')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'s')"
      >
        <div
          style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:28px;height:3px;background:white;border-radius:2px"
        >
        </div>
      </div>
      <!-- W -->
      <div
        class="absolute pointer-events-auto"
        style="left:-4px;top:50%;transform:translateY(-50%);width:8px;height:32px;cursor:w-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'w')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'w')"
      >
        <div
          style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:28px;background:white;border-radius:2px"
        >
        </div>
      </div>
      <!-- E -->
      <div
        class="absolute pointer-events-auto"
        style="right:-4px;top:50%;transform:translateY(-50%);width:8px;height:32px;cursor:e-resize;touch-action:none;"
        @mousedown.prevent.stop="startCropResize($event,'e')"
        @touchstart.prevent.stop="startCropResizeTouch($event,'e')"
      >
        <div
          style="position:absolute;right:0;top:50%;transform:translateY(-50%);width:3px;height:28px;background:white;border-radius:2px"
        >
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import Alpine from 'alpinejs'
  import { Renderer } from '../lib/gl/renderer.js'
  import { setupGestures } from '../lib/gestures.js'
  import { updateProject } from '../lib/storage.js'
  import {
    computeHistogramFromBitmap,
    computeHistogramFromRaw,
  } from '../lib/histogram.js'

  Alpine.data('canvasView', () => ({
    zoom: 1,
    panX: 0,
    panY: 0,
    naturalW: 0,
    naturalH: 0,
    panning: false,
    _panStartX: 0,
    _panStartY: 0,
    _panOriginX: 0,
    _panOriginY: 0,
    renderer: null,
    showMinimap: false,
    minimapSize: { w: 160, h: 100 },
    _minimapDirty: false,
    canvasBg: 'black',
    get canvasBgColor() {
      return this.canvasBg === 'white' ? '#ffffff' : this.canvasBg === 'grey' ? '#777777' : '#000000'
    },

    init() {
      const canvas = this.$refs.canvas

      // Create renderer
      this.renderer = new Renderer(canvas)

      // Load image event
      window.addEventListener('editor:loadImage', e => {
        const { bitmap } = e.detail
        this.naturalW = bitmap.width
        this.naturalH = bitmap.height
        canvas.width = bitmap.width
        canvas.height = bitmap.height
        this._setMinimapSize()
        this.renderer.loadImage(bitmap)
        this.renderer.render(Alpine.store('editor'))
        this.$nextTick(() => {
          this.fitToScreen()
          this._scheduleMinimap()
        })
        computeHistogramFromBitmap(bitmap).then(hist => {
          Alpine.store('editor').histogram = hist
        })
      })

      // Load RAW event
      window.addEventListener('editor:loadRaw', e => {
        const { pixels, width, height } = e.detail
        this.naturalW = width
        this.naturalH = height
        canvas.width = width
        canvas.height = height
        this._setMinimapSize()
        this.renderer.loadRawPixels(pixels, width, height)
        this.renderer.render(Alpine.store('editor'))
        this.$nextTick(() => {
          this.fitToScreen()
          this._scheduleMinimap()
        })
        Alpine.store('editor').histogram = computeHistogramFromRaw(pixels)
      })

      // Re-render on explicit editor:render events (undo/redo/reset/presets)
      window.addEventListener('editor:render', () => {
        this.renderer?.render(Alpine.store('editor'))
        this._scheduleMinimap()
      })

      // Debounced save — called from watches so every slider change is captured
      let _saveTimer = null
      const deferSave = () => {
        const store = Alpine.store('editor')
        if (!store.hasImage || store.restoring || !store.currentProjectId)
          return
        clearTimeout(_saveTimer)
        _saveTimer = setTimeout(async () => {
          try {
            const s = Alpine.store('editor')
            if (!s.hasImage || !s.currentProjectId) return
            // Resize to 400px wide thumbnail before saving to keep IndexedDB small
            const src = this.$refs.canvas
            const maxW = 400
            const scale = Math.min(1, maxW / src.width)
            const tw = Math.round(src.width * scale)
            const th = Math.round(src.height * scale)
            const thumb = document.createElement('canvas')
            thumb.width = tw
            thumb.height = th
            thumb.getContext('2d').drawImage(src, 0, 0, tw, th)
            const blob = await new Promise(r => thumb.toBlob(r, 'image/jpeg', 0.7))
            await updateProject(s.currentProjectId, s, blob)
          } catch {
            // Auto-save failure is non-critical
          }
        }, 2000)
      }

      // Watch store edit values — re-render and debounce save on any change
      const renderAndSave = () => {
        this.renderer?.render(Alpine.store('editor'))
        this._scheduleMinimap()
        deferSave()
      }

      this.$watch('$store.editor.light', renderAndSave, { deep: true })
      this.$watch('$store.editor.color', renderAndSave, { deep: true })
      this.$watch('$store.editor.curve', renderAndSave, { deep: true })
      this.$watch('$store.editor.detail', renderAndSave, { deep: true })
      this.$watch('$store.editor.crop', renderAndSave, { deep: true })

      this.$watch('$store.editor.frame', renderAndSave, { deep: true })
      this.$watch('$store.editor.lens', renderAndSave, { deep: true })

      // Enforce aspect ratio whenever the ratio selection changes
      this.$watch('$store.editor.crop.ratio', ratio => {
        if (ratio === 'free' || !this.naturalW || !this.naturalH) return
        const ratioMap = {
          '1:1': 1,
          '4:3': 4 / 3,
          '16:9': 16 / 9,
          '3:2': 3 / 2,
          '9:16': 9 / 16,
        }
        const r = ratioMap[ratio]
        if (!r) return
        const crop = Alpine.store('editor').crop
        const { x, y, w, h } = crop
        const cx = x + w / 2
        const cy = y + h / 2
        // UV ratio: (crop_w * naturalW) / (crop_h * naturalH) = r  =>  crop_w/crop_h = r * naturalH/naturalW
        const uvRatio = (r * this.naturalH) / this.naturalW
        let newW = 1,
          newH = 1 / uvRatio
        if (newH > 1) {
          newH = 1
          newW = newH * uvRatio
        }
        const newX = Math.max(0, Math.min(1 - newW, cx - newW / 2))
        const newY = Math.max(0, Math.min(1 - newH, cy - newH / 2))
        Object.assign(Alpine.store('editor').crop, {
          x: newX,
          y: newY,
          w: newW,
          h: newH,
        })
        Alpine.store('editor').pushHistory()
      })

      // Re-fit when switching in/out of crop panel
      this.$watch('$store.editor.activePanel', () => {
        this.$nextTick(() => this.fitToScreen())
      })

      // Keyboard zoom events (dispatched from index.astro keydown handler)
      window.addEventListener('canvas:zoomIn', () => {
        this.zoom = Math.min(30, this.zoom * 1.2)
        this._onPanZoom()
      })
      window.addEventListener('canvas:zoomOut', () => {
        this.zoom = Math.max(0.05, this.zoom / 1.2)
        this._onPanZoom()
      })
      window.addEventListener('canvas:fitToScreen', () => {
        this.fitToScreen()
      })

      // Gesture setup
      const container = this.$el
      setupGestures(container, {
        doubleTap: () => this.fitToScreen(),
        pinchZoom: ({ scale, dx, dy, cx, cy }) => {
          const newZoom = Math.max(0.05, Math.min(30, this.zoom * scale))
          // Zoom toward the cursor / pinch-center point (cx, cy)
          this.panX = cx - (cx - this.panX) * (newZoom / this.zoom) + dx
          this.panY = cy - (cy - this.panY) * (newZoom / this.zoom) + dy
          this.zoom = newZoom
          this._onPanZoom()
        },
      })

      // Mouse pan (desktop)
      window.addEventListener('mousemove', e => {
        if (!this.panning) return
        this.panX = this._panOriginX + (e.clientX - this._panStartX)
        this.panY = this._panOriginY + (e.clientY - this._panStartY)
        this._scheduleMinimap()
      })
      window.addEventListener('mouseup', () => {
        this.panning = false
      })
    },

    startPan(e) {
      this.panning = true
      this._panStartX = e.clientX
      this._panStartY = e.clientY
      this._panOriginX = this.panX
      this._panOriginY = this.panY
    },

    touchStart(e) {
      // Single finger pan
      if (e.touches.length === 1) {
        this._panStartX = e.touches[0].clientX
        this._panStartY = e.touches[0].clientY
        this._panOriginX = this.panX
        this._panOriginY = this.panY

        const onMove = ev => {
          if (ev.touches.length !== 1) return
          this.panX =
            this._panOriginX + (ev.touches[0].clientX - this._panStartX)
          this.panY =
            this._panOriginY + (ev.touches[0].clientY - this._panStartY)
          this._scheduleMinimap()
        }
        const onEnd = () => {
          window.removeEventListener('touchmove', onMove)
          window.removeEventListener('touchend', onEnd)
        }
        window.addEventListener('touchmove', onMove, { passive: true })
        window.addEventListener('touchend', onEnd, { passive: true })
      }
    },

    // ── Crop overlay helpers ──────────────────────────────────────────

    cropBoxStyle() {
      if (!this.naturalW || !this.naturalH) return ''
      const { x, y, w, h } = this.$store.editor.crop
      const left = this.panX + x * this.naturalW * this.zoom
      const top = this.panY + y * this.naturalH * this.zoom
      const width = w * this.naturalW * this.zoom
      const height = h * this.naturalH * this.zoom
      return (
        `position:absolute;left:${left}px;top:${top}px;width:${width}px;height:${height}px;` +
        `box-shadow:0 0 0 9999px rgba(0,0,0,0.55);overflow:visible;`
      )
    },

    _clampCrop(x, y, w, h) {
      w = Math.max(0.04, Math.min(1, w))
      h = Math.max(0.04, Math.min(1, h))
      x = Math.max(0, Math.min(1 - w, x))
      y = Math.max(0, Math.min(1 - h, y))
      return { x, y, w, h }
    },

    _enforceRatio(w, h, primary = 'w') {
      const ratio = this.$store.editor.crop.ratio
      if (ratio === 'free') return { w, h }
      const ratioMap = {
        '1:1': 1,
        '4:3': 4 / 3,
        '16:9': 16 / 9,
        '3:2': 3 / 2,
        '9:16': 9 / 16,
      }
      const r = ratioMap[ratio]
      if (!r || !this.naturalW || !this.naturalH) return { w, h }
      const uvRatio = (r * this.naturalH) / this.naturalW
      if (primary === 'w') return { w, h: w / uvRatio }
      return { w: h * uvRatio, h }
    },

    startCropDrag(e) {
      const startX = e.clientX,
        startY = e.clientY
      const { x: ox, y: oy, w: ow, h: oh } = { ...this.$store.editor.crop }
      const onMove = ev => {
        const dx = (ev.clientX - startX) / (this.naturalW * this.zoom)
        const dy = (ev.clientY - startY) / (this.naturalH * this.zoom)
        const c = this._clampCrop(ox + dx, oy + dy, ow, oh)
        Object.assign(this.$store.editor.crop, { x: c.x, y: c.y })
      }
      const onUp = () => {
        window.removeEventListener('mousemove', onMove)
        window.removeEventListener('mouseup', onUp)
        this.$store.editor.pushHistory()
      }
      window.addEventListener('mousemove', onMove)
      window.addEventListener('mouseup', onUp)
    },

    startCropDragTouch(e) {
      const touch = e.touches[0]
      const startX = touch.clientX,
        startY = touch.clientY
      const { x: ox, y: oy, w: ow, h: oh } = { ...this.$store.editor.crop }
      const onMove = ev => {
        ev.preventDefault()
        const t = ev.touches[0]
        const dx = (t.clientX - startX) / (this.naturalW * this.zoom)
        const dy = (t.clientY - startY) / (this.naturalH * this.zoom)
        const c = this._clampCrop(ox + dx, oy + dy, ow, oh)
        Object.assign(this.$store.editor.crop, { x: c.x, y: c.y })
      }
      const onEnd = () => {
        window.removeEventListener('touchmove', onMove)
        window.removeEventListener('touchend', onEnd)
        this.$store.editor.pushHistory()
      }
      window.addEventListener('touchmove', onMove, { passive: false })
      window.addEventListener('touchend', onEnd)
    },

    startCropResize(e, handle) {
      const startX = e.clientX,
        startY = e.clientY
      const { x: ox, y: oy, w: ow, h: oh } = { ...this.$store.editor.crop }
      const scaleX = this.naturalW * this.zoom
      const scaleY = this.naturalH * this.zoom
      const isH = /[ew]/.test(handle)
      const onMove = ev => {
        const dx = (ev.clientX - startX) / scaleX
        const dy = (ev.clientY - startY) / scaleY
        let x = ox,
          y = oy,
          w = ow,
          h = oh
        if (handle.includes('e')) w = Math.max(0.04, ow + dx)
        if (handle.includes('s')) h = Math.max(0.04, oh + dy)
        if (handle.includes('w')) {
          x = ox + dx
          w = Math.max(0.04, ow - dx)
        }
        if (handle.includes('n')) {
          y = oy + dy
          h = Math.max(0.04, oh - dy)
        }
        const r = this._enforceRatio(w, h, isH ? 'w' : 'h')
        w = r.w
        h = r.h
        if (handle.includes('w')) x = ox + ow - w
        if (handle.includes('n')) y = oy + oh - h
        const c = this._clampCrop(x, y, w, h)
        Object.assign(this.$store.editor.crop, c)
      }
      const onUp = () => {
        window.removeEventListener('mousemove', onMove)
        window.removeEventListener('mouseup', onUp)
        this.$store.editor.pushHistory()
      }
      window.addEventListener('mousemove', onMove)
      window.addEventListener('mouseup', onUp)
    },

    startCropResizeTouch(e, handle) {
      const touch = e.touches[0]
      const startX = touch.clientX,
        startY = touch.clientY
      const { x: ox, y: oy, w: ow, h: oh } = { ...this.$store.editor.crop }
      const scaleX = this.naturalW * this.zoom
      const scaleY = this.naturalH * this.zoom
      const isH = /[ew]/.test(handle)
      const onMove = ev => {
        ev.preventDefault()
        const t = ev.touches[0]
        const dx = (t.clientX - startX) / scaleX
        const dy = (t.clientY - startY) / scaleY
        let x = ox,
          y = oy,
          w = ow,
          h = oh
        if (handle.includes('e')) w = Math.max(0.04, ow + dx)
        if (handle.includes('s')) h = Math.max(0.04, oh + dy)
        if (handle.includes('w')) {
          x = ox + dx
          w = Math.max(0.04, ow - dx)
        }
        if (handle.includes('n')) {
          y = oy + dy
          h = Math.max(0.04, oh - dy)
        }
        const r = this._enforceRatio(w, h, isH ? 'w' : 'h')
        w = r.w
        h = r.h
        if (handle.includes('w')) x = ox + ow - w
        if (handle.includes('n')) y = oy + oh - h
        const c = this._clampCrop(x, y, w, h)
        Object.assign(this.$store.editor.crop, c)
      }
      const onEnd = () => {
        window.removeEventListener('touchmove', onMove)
        window.removeEventListener('touchend', onEnd)
        this.$store.editor.pushHistory()
      }
      window.addEventListener('touchmove', onMove, { passive: false })
      window.addEventListener('touchend', onEnd)
    },

    cropClipPath() {
      const { x, y, w, h } = this.$store.editor.crop
      const top = (y * 100).toFixed(3) + '%'
      const right = ((1 - x - w) * 100).toFixed(3) + '%'
      const bottom = ((1 - y - h) * 100).toFixed(3) + '%'
      const left = (x * 100).toFixed(3) + '%'
      return `inset(${top} ${right} ${bottom} ${left})`
    },

    fitToScreen() {
      const container = this.$el
      const cw = container.clientWidth
      const ch = container.clientHeight
      if (!this.naturalW || !this.naturalH) return
      if (!cw || !ch) {
        requestAnimationFrame(() => this.fitToScreen())
        return
      }
      const inCropPanel = this.$store.editor.activePanel === 'crop'
      const crop = this.$store.editor.crop

      if (inCropPanel) {
        // Show full image while editing crop
        const scaleX = cw / this.naturalW
        const scaleY = ch / this.naturalH
        this.zoom = Math.min(scaleX, scaleY) * 0.95
        this.panX = (cw - this.naturalW * this.zoom) / 2
        this.panY = (ch - this.naturalH * this.zoom) / 2
      } else {
        // Fit the crop region to the viewport
        const cropPxW = crop.w * this.naturalW
        const cropPxH = crop.h * this.naturalH
        const scaleX = cw / cropPxW
        const scaleY = ch / cropPxH
        this.zoom = Math.min(scaleX, scaleY) * 0.95
        // Position full canvas so the crop region is centred
        const screenCropW = cropPxW * this.zoom
        const screenCropH = cropPxH * this.zoom
        this.panX = (cw - screenCropW) / 2 - crop.x * this.naturalW * this.zoom
        this.panY = (ch - screenCropH) / 2 - crop.y * this.naturalH * this.zoom
      }
      this._onPanZoom()
    },

    _onPanZoom() {
      const container = this.$el
      if (!container || !this.naturalW) return
      this.showMinimap =
        this.naturalW * this.zoom > container.clientWidth ||
        this.naturalH * this.zoom > container.clientHeight
      this._scheduleMinimap()
    },

    _scheduleMinimap() {
      if (this._minimapDirty) return
      this._minimapDirty = true
      requestAnimationFrame(() => {
        this._minimapDirty = false
        this._drawMinimap()
      })
    },

    _setMinimapSize() {
      const maxW = 160,
        maxH = 100
      if (!this.naturalW || !this.naturalH) {
        this.minimapSize = { w: maxW, h: maxH }
        return
      }
      const ratio = this.naturalW / this.naturalH
      if (ratio > maxW / maxH) {
        this.minimapSize = { w: maxW, h: Math.round(maxW / ratio) }
      } else {
        this.minimapSize = { w: Math.round(maxH * ratio), h: maxH }
      }
    },

    _drawMinimap() {
      const mm = this.$refs.minimap
      if (!mm || !this.naturalW || !this.naturalH) return
      const ctx = mm.getContext('2d')
      const mmW = mm.width
      const mmH = mm.height
      if (!mmW || !mmH) return

      // Full image dimmed
      ctx.clearRect(0, 0, mmW, mmH)
      ctx.globalAlpha = 0.45
      try {
        ctx.drawImage(this.$refs.canvas, 0, 0, mmW, mmH)
      } catch {
        return
      }
      ctx.globalAlpha = 1

      // Visible region in normalised image coords [0..1]
      const container = this.$el
      const cw = container.clientWidth
      const ch = container.clientHeight
      const visL = Math.max(0, -this.panX / (this.zoom * this.naturalW))
      const visT = Math.max(0, -this.panY / (this.zoom * this.naturalH))
      const visR = Math.min(1, (cw - this.panX) / (this.zoom * this.naturalW))
      const visB = Math.min(1, (ch - this.panY) / (this.zoom * this.naturalH))

      const rx = visL * mmW
      const ry = visT * mmH
      const rw = Math.max(0, (visR - visL) * mmW)
      const rh = Math.max(0, (visB - visT) * mmH)

      // Redraw viewport area at full brightness via clip
      if (rw > 0 && rh > 0) {
        ctx.save()
        ctx.beginPath()
        ctx.rect(rx, ry, rw, rh)
        ctx.clip()
        ctx.drawImage(this.$refs.canvas, 0, 0, mmW, mmH)
        ctx.restore()
      }

      // Viewport border
      ctx.strokeStyle = 'rgba(255,255,255,0.85)'
      ctx.lineWidth = 1.5
      ctx.strokeRect(
        rx + 0.75,
        ry + 0.75,
        Math.max(0, rw - 1.5),
        Math.max(0, rh - 1.5),
      )
    },
  }))
</script>

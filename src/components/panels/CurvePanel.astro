---
---
<div x-data="curveEditor()" class="flex flex-col gap-3 pt-2">
  <!-- Channel selector -->
  <div class="flex gap-1.5">
    <template x-for="ch in ['RGB','R','G','B']" :key="ch">
      <button
        class="flex-1 py-1.5 font-mono text-[9px] uppercase tracking-wider border rounded-lg transition-all"
        :class="$store.editor.curve.channel === ch.toLowerCase()
          ? 'border-white bg-white text-black'
          : 'border-white/10 text-white/35 hover:text-white/60 hover:border-white/25'"
        @click="$store.editor.curve.channel = ch.toLowerCase()"
        x-text="ch"
      ></button>
    </template>
  </div>

  <!-- SVG curve canvas -->
  <div
    class="relative rounded-xl overflow-hidden border border-white/[0.06] bg-white/[0.02]"
    style="aspect-ratio: 1"
  >
    <svg
      class="w-full h-full select-none touch-none"
      viewBox="0 0 256 256"
      x-ref="svg"
      @mousedown="onMouseDown($event)"
      @touchstart.prevent="onTouchStart($event)"
    >
      <!-- Histogram background — x-show on individual paths (x-if breaks inside SVG) -->
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'rgb'" :d="buildHistPath($store.editor.histogram?.r)" fill="#ef4444" fill-opacity="0.18" />
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'rgb'" :d="buildHistPath($store.editor.histogram?.g)" fill="#22c55e" fill-opacity="0.18" />
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'rgb'" :d="buildHistPath($store.editor.histogram?.b)" fill="#3b82f6" fill-opacity="0.18" />
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'r'" :d="buildHistPath($store.editor.histogram?.r)" fill="#ef4444" fill-opacity="0.25" />
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'g'" :d="buildHistPath($store.editor.histogram?.g)" fill="#22c55e" fill-opacity="0.25" />
      <path x-show="$store.editor.histogram && $store.editor.curve.channel === 'b'" :d="buildHistPath($store.editor.histogram?.b)" fill="#3b82f6" fill-opacity="0.25" />

      <!-- Grid -->
      <line x1="64"  y1="0" x2="64"  y2="256" stroke="white" stroke-opacity="0.04" />
      <line x1="128" y1="0" x2="128" y2="256" stroke="white" stroke-opacity="0.04" />
      <line x1="192" y1="0" x2="192" y2="256" stroke="white" stroke-opacity="0.04" />
      <line x1="0" y1="64"  x2="256" y2="64"  stroke="white" stroke-opacity="0.04" />
      <line x1="0" y1="128" x2="256" y2="128" stroke="white" stroke-opacity="0.04" />
      <line x1="0" y1="192" x2="256" y2="192" stroke="white" stroke-opacity="0.04" />
      <!-- Diagonal reference -->
      <line x1="0" y1="256" x2="256" y2="0" stroke="white" stroke-opacity="0.06" stroke-dasharray="4 4" />

      <!-- Inactive channel curves (ghost hints) — x-show instead of x-if -->
      <path x-show="$store.editor.curve.channel !== 'r'" :d="buildPath('r')" fill="none" stroke="#ef4444" stroke-opacity="0.2" stroke-width="1" stroke-linecap="round" />
      <path x-show="$store.editor.curve.channel !== 'g'" :d="buildPath('g')" fill="none" stroke="#22c55e" stroke-opacity="0.2" stroke-width="1" stroke-linecap="round" />
      <path x-show="$store.editor.curve.channel !== 'b'" :d="buildPath('b')" fill="none" stroke="#3b82f6" stroke-opacity="0.2" stroke-width="1" stroke-linecap="round" />

      <!-- Active curve -->
      <path
        :d="curvePath"
        fill="none"
        :stroke="channelColor"
        stroke-opacity="0.9"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />

      <!-- Control points — x-html on <g> avoids x-for inside SVG (template namespace bug) -->
      <g x-html="renderPointsSvg"></g>
    </svg>
  </div>

  <!-- Hint -->
  <p class="font-mono text-[8px] text-white/20 text-center tracking-wider">CLICK TO ADD · DOUBLE-CLICK TO REMOVE</p>

  <!-- Reset curve -->
  <button
    class="w-full py-2 font-mono text-[9px] uppercase tracking-[0.15em] border border-white/10 rounded-lg text-white/30 hover:text-white/55 hover:border-white/25 transition-all"
    @click="resetCurve()"
  >
    RESET CURVE
  </button>
</div>

<script>
import Alpine from 'alpinejs'
import { buildCurvePath } from '../../lib/bezier.js'

Alpine.data('curveEditor', () => ({
  _draggingIndex: null,
  _hasDragged: false,
  _lastTapTime: 0,

  get currentPoints() {
    const ch = this.$store.editor.curve.channel
    return this.$store.editor.curve[ch]
  },

  get curvePath() {
    return buildCurvePath(this.currentPoints, 256, 256)
  },

  get channelColor() {
    const ch = this.$store.editor.curve.channel
    if (ch === 'r') return '#ef4444'
    if (ch === 'g') return '#22c55e'
    if (ch === 'b') return '#3b82f6'
    return 'white'
  },

  // Generates SVG circle markup for control points.
  // x-html on a <g> sets innerHTML in SVG context, so circles parse correctly.
  get renderPointsSvg() {
    const color = this.channelColor
    const r = 4
    return this.currentPoints.map(pt => {
      const cx = Math.max(r, Math.min(256 - r, pt[0] * 256)).toFixed(2)
      const cy = Math.max(r, Math.min(256 - r, (1 - pt[1]) * 256)).toFixed(2)
      return `<circle cx="${cx}" cy="${cy}" r="${r}" fill="#000" stroke="${color}" stroke-width="1.5"/>`
    }).join('')
  },

  buildPath(ch) {
    return buildCurvePath(this.$store.editor.curve[ch], 256, 256)
  },

  buildHistPath(data) {
    if (!data) return ''
    let maxVal = 0
    for (let i = 0; i < 256; i++) if (data[i] > maxVal) maxVal = data[i]
    if (maxVal === 0) return ''
    const logMax = Math.log1p(maxVal)
    let d = 'M 0,256'
    for (let i = 0; i < 256; i++) {
      const h = (Math.log1p(data[i]) / logMax) * 210
      d += ` L ${i + 0.5},${(256 - h).toFixed(1)}`
    }
    d += ' L 256,256 Z'
    return d
  },

  getSvgPoint(clientX, clientY) {
    const svg = this.$refs.svg
    const rect = svg.getBoundingClientRect()
    const x = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width))
    const y = Math.max(0, Math.min(1, 1 - (clientY - rect.top) / rect.height))
    return [x, y]
  },

  // Unified mouse handler: hit-test first, then add or drag.
  // Double-click on a point removes it.
  onMouseDown(e) {
    const [x, y] = this.getSvgPoint(e.clientX, e.clientY)
    const idx = this._findNearest(x, y, 0.06)
    if (e.detail === 2) {
      if (idx !== -1) this.removePoint(idx)
      return
    }
    if (idx !== -1) {
      this._draggingIndex = idx
    } else {
      this.addPoint(x, y)
    }
    this._hasDragged = false
    const onMove = (ev) => { this._hasDragged = true; this.moveActive(ev.clientX, ev.clientY) }
    const onUp = () => {
      window.removeEventListener('mousemove', onMove)
      window.removeEventListener('mouseup', onUp)
      this._draggingIndex = null
      this.$store.editor.pushHistory()
    }
    window.addEventListener('mousemove', onMove)
    window.addEventListener('mouseup', onUp)
  },

  onTouchStart(e) {
    if (e.touches.length !== 1) return
    const [x, y] = this.getSvgPoint(e.touches[0].clientX, e.touches[0].clientY)
    const now = Date.now()
    if (now - this._lastTapTime < 300) {
      const idx = this._findNearest(x, y, 0.08)
      if (idx !== -1) this.removePoint(idx)
      this._lastTapTime = 0
      return
    }
    this._lastTapTime = now
    const idx = this._findNearest(x, y, 0.08)
    if (idx !== -1) {
      this._draggingIndex = idx
    } else {
      this.addPoint(x, y)
    }
    this._hasDragged = false
    const onMove = (ev) => {
      if (ev.touches.length === 1) { this._hasDragged = true; this.moveActive(ev.touches[0].clientX, ev.touches[0].clientY) }
    }
    const onEnd = () => {
      window.removeEventListener('touchmove', onMove)
      window.removeEventListener('touchend', onEnd)
      this._draggingIndex = null
      this.$store.editor.pushHistory()
    }
    window.addEventListener('touchmove', onMove, { passive: true })
    window.addEventListener('touchend', onEnd)
  },

  addPoint(x, y) {
    const pts = this.currentPoints
    pts.push([x, y])
    pts.sort((a, b) => a[0] - b[0])
    this._draggingIndex = pts.findIndex(p => Math.abs(p[0] - x) < 0.001 && Math.abs(p[1] - y) < 0.001)
  },

  removePoint(index) {
    const pts = this.currentPoints
    if (index === 0 || index === pts.length - 1) return  // protect endpoints
    this._draggingIndex = null
    pts.splice(index, 1)
    this.$store.editor.pushHistory()
  },

  moveActive(clientX, clientY) {
    if (this._draggingIndex === null) return
    const pts = this.currentPoints
    const [x, y] = this.getSvgPoint(clientX, clientY)
    const i = this._draggingIndex
    const newX = (i === 0) ? 0 : (i === pts.length - 1) ? 1 : x
    pts[i] = [newX, y]
    pts.sort((a, b) => a[0] - b[0])
    this._draggingIndex = pts.findIndex(p => p[0] === newX && Math.abs(p[1] - y) < 0.001)
  },

  _findNearest(x, y, threshold = 0.06) {
    const pts = this.currentPoints
    let best = -1, bestDist = threshold
    for (let i = 0; i < pts.length; i++) {
      const d = Math.hypot(pts[i][0] - x, pts[i][1] - y)
      if (d < bestDist) { bestDist = d; best = i }
    }
    return best
  },

  resetCurve() {
    const d = [[0,0],[1,1]]
    this.$store.editor.curve.rgb = d.map(p=>[...p])
    this.$store.editor.curve.r   = d.map(p=>[...p])
    this.$store.editor.curve.g   = d.map(p=>[...p])
    this.$store.editor.curve.b   = d.map(p=>[...p])
    this.$store.editor.curve.channel = 'rgb'
    this.$store.editor.pushHistory()
    window.dispatchEvent(new CustomEvent('editor:render'))
  },
}))
</script>

---
---
<div x-data class="flex flex-col gap-4 pt-2">
  <!-- Aspect ratio -->
  <div>
    <p class="font-mono text-[9px] text-white/25 uppercase tracking-[0.15em] mb-2">ASPECT RATIO</p>
    <div class="grid grid-cols-3 gap-1.5">
      <template x-for="r in ['FREE','1:1','4:3','16:9','3:2','9:16']" :key="r">
        <button
          class="py-2 font-mono text-[9px] uppercase tracking-wider border rounded-lg transition-all"
          :class="$store.editor.crop.ratio === r.toLowerCase()
            ? 'border-white bg-white text-black'
            : 'border-white/10 text-white/35 hover:border-white/30 hover:text-white/60'"
          @click="$store.editor.crop.ratio = r.toLowerCase()"
          x-text="r"
        ></button>
      </template>
    </div>
  </div>

  <!-- Straighten -->
  <div>
    <div class="flex justify-between items-baseline mb-2">
      <p class="font-mono text-[9px] text-white/25 uppercase tracking-[0.15em]">STRAIGHTEN</p>
      <span class="font-mono text-[10px] text-white tabular-nums"
        x-text="(($store.editor.crop.angle > 0 ? '+' : '') + Number($store.editor.crop.angle).toFixed(1)) + '°'"></span>
    </div>
    <div class="relative h-11 flex items-center" x-data="{ _lastTap: 0 }">
      <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-white/[0.12]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-px h-2 bg-white/20"></div>
      <div
        class="absolute top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-sm pointer-events-none -translate-x-1/2"
        :style="`left: ${50 + ($store.editor.crop.angle / 90) * 100}%`"
      ></div>
      <input
        type="range" min="-45" max="45" step="0.5"
        x-model.number="$store.editor.crop.angle"
        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer touch-none"
        @input="$store.editor.straightening = true"
        @change="$store.editor.straightening = false; $store.editor.pushHistory()"
        @touchmove.prevent="
          const r = $el.getBoundingClientRect();
          const p = Math.max(0, Math.min(1, ($event.touches[0].clientX - r.left) / r.width));
          $store.editor.crop.angle = parseFloat((-45 + p * 90).toFixed(1));
          $store.editor.straightening = true;
        "
        @touchend="$store.editor.straightening = false; $store.editor.pushHistory()"
        @touchstart="const now = Date.now(); if (now - _lastTap < 300) { $store.editor.crop.angle = 0; $store.editor.pushHistory(); } _lastTap = now;"
        @dblclick.prevent="$store.editor.crop.angle = 0; $store.editor.pushHistory()"
      />
    </div>
  </div>

  <!-- Accept / Reset -->
  <div class="flex gap-2">
    <button
      class="flex-1 py-2.5 font-mono text-[9px] uppercase tracking-[0.15em] border border-white/10 rounded-lg text-white/35 hover:text-white/60 hover:border-white/25 transition-all"
      @click="$store.editor.crop = { x:0, y:0, w:1, h:1, angle:0, ratio:'free' }; $store.editor.pushHistory()"
    >
      RESET
    </button>
    <button
      class="flex-1 py-2.5 font-mono text-[9px] uppercase tracking-[0.15em] border border-white bg-white text-black rounded-lg hover:bg-white/90 transition-all"
      @click="$store.editor.activePanel = 'light'"
    >
      APPLY
    </button>
  </div>
</div>

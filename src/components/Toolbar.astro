---

---

<!-- Floating glass pill toolbar -->
<div
  class="absolute top-safe-top top-4 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2 px-4 py-2 rounded-full border border-white/8 bg-black/50 backdrop-blur-xl max-w-[calc(100vw-2rem)]"
  x-data="toolbar()"
  x-show="$store.editor.hasImage && !$store.editor.libraryOpen"
  x-cloak
  style="top: max(16px, env(safe-area-inset-top))"
>
  <!-- Filename -->
  <span
    class="font-mono text-[10px] text-white/60 uppercase tracking-widest min-w-0 truncate"
    x-text="$store.editor.filename.replace(/\.[^.]+$/, '').toUpperCase().slice(0, 16)"
  ></span>

  <div class="w-px h-3 bg-white/10 mx-1"></div>

  <!-- Undo -->
  <button
    class="w-6 h-6 flex items-center justify-center text-white/50 hover:text-white transition-colors rounded"
    @click="$store.editor.undo()"
    title="Undo"
    aria-label="Undo"
  >
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path
        d="M2 5 C2 2.8 3.8 1 6 1 C8.2 1 10 2.8 10 5 C10 7.2 8.2 9 6 9 L4 9"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        fill="none"></path>
      <polyline
        points="2,3 2,6 5,6"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"></polyline>
    </svg>
  </button>

  <!-- Redo -->
  <button
    class="w-6 h-6 flex items-center justify-center text-white/50 hover:text-white transition-colors rounded"
    @click="$store.editor.redo()"
    title="Redo"
    aria-label="Redo"
  >
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path
        d="M10 5 C10 2.8 8.2 1 6 1 C3.8 1 2 2.8 2 5 C2 7.2 3.8 9 6 9 L8 9"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        fill="none"></path>
      <polyline
        points="10,3 10,6 7,6"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"></polyline>
    </svg>
  </button>

  <div class="w-px h-3 bg-white/10 mx-1"></div>

  <!-- Reset -->
  <button
    class="font-mono text-[9px] text-white/40 hover:text-white/70 uppercase tracking-widest transition-colors px-1"
    @click="$store.editor.resetEdits()"
  >
    RESET
  </button>

  <div class="w-px h-3 bg-white/10 mx-1"></div>

  <!-- Open library -->
  <button
    class="w-6 h-6 flex items-center justify-center text-white/50 hover:text-white transition-colors rounded"
    @click="$store.editor.libraryOpen = true"
    title="Image library"
    aria-label="Image library"
  >
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <rect x="1" y="1" width="4" height="4" rx="0.8" stroke="currentColor" stroke-width="1.1" fill="none"/>
      <rect x="7" y="1" width="4" height="4" rx="0.8" stroke="currentColor" stroke-width="1.1" fill="none"/>
      <rect x="1" y="7" width="4" height="4" rx="0.8" stroke="currentColor" stroke-width="1.1" fill="none"/>
      <rect x="7" y="7" width="4" height="4" rx="0.8" stroke="currentColor" stroke-width="1.1" fill="none"/>
    </svg>
  </button>

  <!-- Export button -->
  <button
    class="ml-1 px-4 py-1.5 bg-white text-black font-mono text-[9px] uppercase tracking-[0.15em] rounded-full hover:bg-white/90 active:bg-white/80 transition-colors"
    @click="$store.editor.exportOpen = true"
  >
    EXPORT
  </button>

</div>

<!-- Export dialog -->
<div
  class="absolute inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
  x-data="exportDialog()"
  x-show="$store.editor.exportOpen"
  x-cloak
  @click.self="$store.editor.exportOpen = false"
  @keydown.escape.window="$store.editor.exportOpen = false"
>
  <div
    class="flex flex-col gap-5 p-6 w-70 rounded-2xl border border-white/8 bg-black/90 backdrop-blur-xl"
  >
    <div class="flex items-center justify-between">
      <p
        class="font-mono text-[10px] text-white/60 uppercase tracking-[0.15em]"
      >
        Export Image
      </p>
      <button
        class="text-white/40 hover:text-white/70 transition-colors"
        @click="$store.editor.exportOpen = false"
      >
        <svg width="12" height="12" viewBox="0 0 12 12">
          <line
            x1="1"
            y1="1"
            x2="11"
            y2="11"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"></line>
          <line
            x1="11"
            y1="1"
            x2="1"
            y2="11"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"></line>
        </svg>
      </button>
    </div>

    <!-- Format selector -->
    <div class="flex flex-col gap-2">
      <label
        class="font-mono text-[9px] text-white/40 uppercase tracking-widest"
        >Format</label
      >
      <div class="grid grid-cols-2 gap-1.5">
        <button
          class="py-2 font-mono text-[9px] uppercase tracking-wider border rounded-lg transition-all"
          :class="format === 'image/jpeg' ? 'border-white bg-white text-black' : 'border-white/10 text-white/40 hover:border-white/25 hover:text-white/60'"
          @click="format = 'image/jpeg'">JPEG</button
        >
        <button
          class="py-2 font-mono text-[9px] uppercase tracking-wider border rounded-lg transition-all"
          :class="format === 'image/png' ? 'border-white bg-white text-black' : 'border-white/10 text-white/40 hover:border-white/25 hover:text-white/60'"
          @click="format = 'image/png'">PNG</button
        >
      </div>
    </div>

    <!-- Quality slider -->
    <div class="flex flex-col gap-1" x-show="format !== 'image/png'">
      <div class="flex justify-between items-baseline mb-1">
        <label
          class="font-mono text-[9px] text-white/40 uppercase tracking-widest"
          >Quality</label
        >
        <span
          class="font-mono text-[10px] text-white tabular-nums"
          x-text="Math.round(quality * 100) + '%'"></span>
      </div>
      <!-- Same custom track pattern as Slider.astro -->
      <div class="relative h-11 flex items-center">
        <!-- Track background -->
        <div
          class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-white/12"
        >
        </div>
        <!-- Filled track: unipolar, left-anchored -->
        <div
          class="absolute top-1/2 -translate-y-1/2 h-px bg-white/70 left-0"
          :style="`right: ${100 - (quality - 0.5) / 0.5 * 100}%`"
        >
        </div>
        <!-- Custom thumb -->
        <div
          class="absolute top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-sm pointer-events-none -translate-x-1/2"
          :style="`left: ${(quality - 0.5) / 0.5 * 100}%`"
        >
        </div>
        <!-- Invisible range input (full touch target) -->
        <input
          type="range"
          min="0.5"
          max="1"
          step="0.01"
          x-model.number="quality"
          class="absolute inset-0 w-full h-full opacity-0 cursor-pointer touch-none"
          @touchmove.prevent="
            const r = $el.getBoundingClientRect();
            const p = Math.max(0, Math.min(1, ($event.touches[0].clientX - r.left) / r.width));
            quality = parseFloat((0.5 + p * 0.5).toFixed(2));
          "
          @touchstart="const now = Date.now(); if (now - _lastTap < 300) { quality = 0.92; } _lastTap = now;"
        />
      </div>
    </div>

    <!-- Action buttons -->
    <div class="flex gap-2 mt-1">
      <button
        class="flex-1 py-2.5 font-mono text-[9px] uppercase tracking-widest border border-white/10 rounded-lg text-white/40 hover:text-white/70 transition-colors"
        @click="$store.editor.exportOpen = false">Cancel</button
      >
      <button
        class="flex-1 py-2.5 font-mono text-[9px] uppercase tracking-[0.15em] bg-white text-black rounded-lg hover:bg-white/90 transition-colors"
        @click="doExport()">Download</button
      >
    </div>
  </div>
</div>

<script>
  import Alpine from 'alpinejs'

  Alpine.data('toolbar', () => ({}))

  Alpine.data('exportDialog', () => ({
    format: 'image/jpeg',
    quality: 0.92,
    _lastTap: 0,

    doExport() {
      const glCanvas = document.getElementById('gl-canvas')
      if (!glCanvas) return
      const store = Alpine.store('editor')
      const { format, quality } = this
      const ext = format === 'image/png' ? 'png' : 'jpg'
      const basename = store.filename.replace(/\.[^.]+$/, '') || 'edited'

      // Crop is only a CSS clip-path — blit the crop sub-rect into a
      // temporary 2D canvas so the export reflects the actual crop region.
      const { x, y, w, h } = store.crop
      const srcX = Math.round(x * glCanvas.width)
      const srcY = Math.round(y * glCanvas.height)
      const srcW = Math.round(w * glCanvas.width)
      const srcH = Math.round(h * glCanvas.height)

      const tmp = document.createElement('canvas')
      tmp.width = srcW
      tmp.height = srcH
      const ctx = tmp.getContext('2d')
      ctx.drawImage(glCanvas, srcX, srcY, srcW, srcH, 0, 0, srcW, srcH)

      tmp.toBlob(
        blob => {
          if (!blob) return
          const url = URL.createObjectURL(blob)
          const a = document.createElement('a')
          a.href = url
          a.download = `${basename}_edited.${ext}`
          document.body.appendChild(a)
          a.click()
          document.body.removeChild(a)
          URL.revokeObjectURL(url)
          store.exportOpen = false
        },
        format,
        quality,
      )
    },
  }))
</script>

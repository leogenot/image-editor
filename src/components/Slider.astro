---
interface Props {
  label: string
  storeKey: string // Alpine.js expression e.g. "$store.editor.light.exposure"
  min?: number
  max?: number
  step?: number
  decimals?: number
  defaultValue?: number
}
const {
  label,
  storeKey,
  min = -1,
  max = 1,
  step = 0.01,
  decimals = 2,
  defaultValue = 0,
} = Astro.props
const range = Number(max) - Number(min)
const pos = `(${storeKey} - ${min}) / ${range} * 100`
const bipolar = Number(min) < 0
---

<div class="py-2.5 border-b border-white/4 last:border-0">
  <div class="flex justify-between items-center mb-2">
    <span class="font-mono text-[9px] uppercase tracking-[0.15em] text-white/40"
      >{label}</span
    >
    <div class="flex items-center gap-1.5">
      <span
        class="font-mono text-[10px] text-white tabular-nums"
        x-text={bipolar
        ? `(${storeKey} > 0 ? '+' : '') + Number(${storeKey}).toFixed(${decimals})`
        : `Number(${storeKey}).toFixed(${decimals})`}
      ></span>
      <button
        class="opacity-0 transition-opacity text-white/30 hover:text-white/70"
        :class={`${storeKey} !== ${defaultValue} ? 'opacity-100' : ''`}
        @click={`${storeKey} = ${defaultValue}; $store.editor.pushHistory(); window.dispatchEvent(new CustomEvent('editor:render'))`}
        title="Reset"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
          <path d="M3 3v5h5"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Slider track + thumb container (44px touch target) -->
  <div class="relative h-11 flex items-center" x-data="{ _lastTap: 0 }">
    <!-- Track background -->
    <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-white/12">
    </div>

    <!-- Filled track portion -->
    <div
      class="absolute top-1/2 -translate-y-1/2 h-px bg-white/70"
      :style={bipolar
        ? `\`left: \${Math.min(50, ${pos})}%;right: \${100 - Math.max(50, ${pos})}%;\``
        : `\`left: 0%;right: \${100 - ${pos}}%;\``}
    >
    </div>

    <!-- Center tick mark (bipolar only) -->
    {bipolar && (
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-px h-2 bg-white/20"
      >
      </div>
    )}

    <!-- Custom thumb -->
    <div
      class="absolute top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-sm pointer-events-none -translate-x-1/2"
      :style={`\`left: \${${pos}}%\``}
    >
    </div>

    <!-- Actual range input (invisible, full-size touch target) -->
    <input
      type="range"
      class="absolute inset-0 w-full h-full opacity-0 cursor-pointer touch-none"
      aria-label={label}
      :min={`${min}`}
      :max={`${max}`}
      :step={`${step}`}
      :value={storeKey}
      x-model.number={storeKey}
      @change={`$store.editor.pushHistory()`}
      @touchmove.prevent={`
        const r = $el.getBoundingClientRect();
        const p = Math.max(0, Math.min(1, ($event.touches[0].clientX - r.left) / r.width));
        ${storeKey} = parseFloat((${min} + p * ${range}).toFixed(${decimals}));
      `}
      @touchend={`$store.editor.pushHistory()`}
      @touchstart={`const now = Date.now(); if (now - _lastTap < 300) { ${storeKey} = ${defaultValue}; $store.editor.pushHistory(); window.dispatchEvent(new CustomEvent('editor:render')); } _lastTap = now;`}
      @dblclick.prevent={`${storeKey} = ${defaultValue}; $store.editor.pushHistory(); window.dispatchEvent(new CustomEvent('editor:render'))`}
    />
  </div>
</div>
